OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional local proxy for networks where Node.js cannot reach api.openai.com directly.
# Example: HTTPS_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=
HTTP_PROXY=
ALL_PROXY=

# Polar credentials remain server-side. Product IDs map the $4.99 Standard and
# $9.99 Full report plans to their Polar products.
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_STANDARD_PRODUCT_ID=73bf4f74-27df-477c-ad25-e14dbd238e70
POLAR_FULL_PRODUCT_ID=37e6e212-82af-4021-ac34-efd03c3d2e13

NEXT_PUBLIC_APP_URL=https://resunexx.com

# Required for report persistence in local and production environments.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Retention windows for encrypted Redis report records. Defaults are 1 hour while
# processing, 1 day for free previews, and 30 days for paid reports.
REPORT_PROCESSING_TTL_SECONDS=3600
REPORT_FREE_TTL_SECONDS=86400
REPORT_PAID_TTL_SECONDS=2592000

# Vercel Marketplace may inject these standard Upstash names instead.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
