OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional local proxy for networks where Node.js cannot reach api.openai.com directly.
# Example: HTTPS_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=
HTTP_PROXY=
ALL_PROXY=

PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
# Explicit price IDs are the production source of truth for the $4.99 and $9.99 report plans.
PADDLE_STANDARD_PRICE_ID=
PADDLE_FULL_PRICE_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required for report persistence in local and production environments.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel Marketplace may inject these standard Upstash names instead.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
