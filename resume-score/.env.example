OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional local proxy for networks where Node.js cannot reach api.openai.com directly.
# Example: HTTPS_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=
HTTP_PROXY=
ALL_PROXY=

PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional but recommended for Vercel production.
# Without KV, local dev uses in-memory storage and reports disappear on server restart.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Standard Upstash names are also supported as an alternative to KV_REST_API_*.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
